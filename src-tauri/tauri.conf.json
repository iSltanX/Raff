{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Raff",
  "version": "2.1.1",
  "identifier": "com.raff.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "panel",
        "title": "رفّ",
        "url": "index.html",
        "width": 392,
        "height": 620,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": false,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "acceptFirstMouse": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app", "dmg"],
    "category": "Productivity",
    "shortDescription": "رفّ — مدير الحافظة الشخصي والخاص لنظام macOS",
    "resources": ["icons/icon-light.icns", "icons/icon-dark.icns"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/iSltanX/Raff-releases/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlFQTY2ODYwNkRDMjQ4Q0QKUldUTlNNSnRZR2ltbmhBcHRDci9HSWlYbzAvQW1jcWtwQUsrOVU2OS9Ec1RsK01QUk1KRy8xb0gK"
    }
  }
}
